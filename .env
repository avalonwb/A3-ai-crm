# Qwen3 api key
QWEN3_API_KEY=<写你的密钥>
# Qwen3 api url
QWEN3_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Qwen3 llm model
QWEN3_MODEL=qwen-plus
# Qwen3 embeding model
QWEN3_EMBEDING_MODEL=text-embedding-v3
# Qwen3 model temperature
QWEN3_MODEL_TEMPERATURE=0
# Qwen3 timeout
QWEN3_TIMEOUT=30
# Qwen3 retries
QWEN3_MAX_RETRIES=3

# SQLite DB PATH
SQL_AGENT_DB_PATH=db/app.db

# Tavily api key
TAVILY_API_KEY=<写你的密钥>
